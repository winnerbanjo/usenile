{
  "version": 2,
  "builds": [
    {
      "src": "api/app.js",
      "use": "@vercel/node",
      "config": {
        "includeFiles": [
          "*.html",
          "src/**",
          "public/**",
          "robots.txt"
        ]
      }
    }
  ],
  "routes": [
    {
      "src": "/(.*)",
      "dest": "/api/app.js"
    }
  ]
}
